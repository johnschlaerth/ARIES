{
  "run_mode": "mock",
  "openai": {
    "enabled": false,
    "model": "gpt-4o-mini",
    "api_key_env_var": "OPENAI_API_KEY",
    "timeout_seconds": 20,
    "max_retries": 2,
    "image_max_side_px": 512,
    "cache_results": true
  },
  "simulation": {
    "seed": 48,
    "time_step_seconds": 1.0,
    "max_steps": 3000,
    "auto_start": false,
    "start_paused": true,
    "friendly_fire_enabled": false,
    "terrain_enabled": true,
    "network_enabled": true,
    "output_reports": true,
    "record_replay": true
  },
  "scenario_generation": {
    "enabled": true,
    "mode": "random_on_run",
    "seed": null,
    "min_enemies": 6,
    "max_enemies": 10,
    "max_neutrals": 6,
    "max_image_assignments": 3,
    "map_width": 2000,
    "map_height": 1400,
    "contour_count": 18,
    "terrain_grid_size": 120,
    "contour_dot_stride": 1,
    "write_generated_scenario": true,
    "generated_scenario_file": "scenarios/generated_latest.json"
  },
  "display": {
    "width": 1400,
    "height": 900,
    "fps": 30,
    "style": "retro_1980s",
    "show_vectors": true,
    "show_paths": true,
    "show_scores": true,
    "show_legend": true,
    "show_event_log": true,
    "show_effect_ranges": true
  },
  "paths": {
    "scenario_file": "scenarios/demo_scenario.json",
    "image_folder": "data/images",
    "classification_cache": "outputs/classification_cache.json",
    "report_folder": "outputs/reports",
    "replay_folder": "outputs/replays"
  }
}